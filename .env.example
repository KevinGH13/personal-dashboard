# Dashboard – Variables de entorno
# Copia este archivo a .env.local para desarrollo local
# Configura estas variables en el panel de Vercel antes de desplegar

# ─── Calendario (ICS feeds) ───────────────────────────────────
# Obtén la URL ICS de Google Calendar:
#   Google Calendar → Configuración → [tu calendario] →
#   "Integrar calendario" → "Dirección secreta en formato iCal"
#
CAL_NAME_1=Mi Calendario
CAL_ICS_1=https://calendar.google.com/calendar/ical/XXXXXXXXXX/private-YYYYYY/basic.ics

# Segundo calendario (opcional)
CAL_NAME_2=Trabajo
CAL_ICS_2=
